WEBUI_PORT=8080
TZ=Europe/Berlin
ISHIKU_LOG_LEVEL=info
ISHIKU_SETUP_SECRET=replace-with-a-long-random-secret
DV2_ACCESS_LOG=false
# Legacy alias. Prefer ISHIKU_SETUP_SECRET for new deployments.
DV2_SHARED_SECRET=replace-with-a-long-random-secret
# ZimaOS default:
MEIKU_DATA_PATH=/DATA/AppData/meiku/data
# Backward-compatible legacy variable:
# DATELLO_DATA_PATH=/DATA/AppData/meiku/data
# Windows Docker Desktop local testing alternative:
# MEIKU_DATA_PATH=./data
