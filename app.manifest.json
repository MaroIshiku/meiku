{
  "schema_version": "1.2.0",
  "app_id": "meiku",
  "app_name": "Meiku",
  "app_subtitle": "Profile Share",
  "primary_purpose": "Teilt private und geschaeftliche Kontaktdaten mit lokalen Profil-, Kontakt- und Zahlungs-QR-Karten.",
  "app_symbol": "badge",
  "app_logo": {
    "src": "assets/meiku-logo-20260628.png",
    "favicon": "assets/meiku-favicon-20260628.png",
    "pwa_icon_192": "assets/meiku-icon-192-20260628.png",
    "pwa_icon_512": "assets/meiku-icon-512-20260628.png",
    "pwa_maskable_512": "assets/meiku-icon-512-20260628.png",
    "alt": "",
    "use_as_header_symbol": true,
    "use_as_favicon": true,
    "use_as_pwa_icon": true,
    "use_as_about_symbol": true,
    "use_as_profile_sheet_symbol": true,
    "use_as_empty_state_symbol": true
  },
  "default_theme": "lavender",
  "default_mode": "system",
  "has_account": true,
  "user_identity_fields": ["avatar", "initials", "display_name", "email"],
  "main_sections": [
    { "id": "privat", "label": "Privat", "icon": "account_circle" },
    { "id": "firma", "label": "Firma", "icon": "badge" },
    { "id": "paypal", "label": "PayPal", "icon": "qr_code" },
    { "id": "bank", "label": "Bank", "icon": "qr_code" }
  ],
  "first_run_setup": {
    "enabled": false,
    "reason": "Meiku ist kein Server-Account-System mit Admin-Datenbank. Die Ersteinrichtung erstellt einen lokal verschluesselten Profil-Tresor; der Server speichert nur den verschluesselten Token.",
    "require_setup_secret": true,
    "setup_secret_file_env": "ISHIKU_SETUP_SECRET_FILE",
    "setup_secret_env": "ISHIKU_SETUP_SECRET",
    "setup_secret_file_default": "/run/secrets/ishiku_setup_secret"
  },
  "technical_info": {
    "allowed_locations": ["Settings", "Debug"],
    "disallowed_locations": ["AppHeader", "main footer"]
  },
  "navigation_complexity": "few_sections",
  "readme_profile": {
    "repository_name": "meiku",
    "github_owner": "MaroIshiku",
    "public_repository": true,
    "short_description": "Meiku ist eine self-hosted Profil- und Kontaktkarten-App im Pixel Soft Utility Designsystem.",
    "docker_image": "ghcr.io/maroishiku/meiku:latest",
    "codex_notice_enabled": true
  }
}
